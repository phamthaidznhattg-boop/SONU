    if input.KeyCode == Enum.KeyCode.T then
        Window:Toggle()
    end
end)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Player = Players.LocalPlayer
local HealData = {
    IsHealing = false,
    SessionID = 0
}

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Standalone_Heal_System"
ScreenGui.Parent = CoreGui
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local HealBtn = Instance.new("TextButton")
HealBtn.Size = UDim2.new(0, 75, 0, 75)
HealBtn.Position = UDim2.new(0.05, 0, 0.52, 0)
HealBtn.Text = "HEAL"
HealBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
HealBtn.TextColor3 = Color3.new(1, 1, 1)
HealBtn.Font = Enum.Font.SourceSansBold
HealBtn.TextSize = 10
HealBtn.Parent = ScreenGui

Instance.new("UICorner", HealBtn).CornerRadius = UDim.new(1, 0)
local Stroke = Instance.new("UIStroke", HealBtn)
Stroke.Color = Color3.new(1, 1, 1)

local function makeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = obj.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    obj.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end
makeDraggable(HealBtn)

HealBtn.MouseButton1Click:Connect(function()
    HealData.IsHealing = not HealData.IsHealing
    HealData.SessionID = HealData.SessionID + 1
    local currentSession = HealData.SessionID
    
    HealBtn.BackgroundColor3 = HealData.IsHealing and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(0, 0, 0)
    HealBtn.Text = HealData.IsHealing and "HEAL: ON" or "HEAL"
    
    if HealData.IsHealing then
        task.spawn(function()
            local char = Player.Character or Player.CharacterAdded:Wait()
            local toolChangeConn
            
            toolChangeConn = char.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and child.Name ~= "Pizza" and child.Name ~= "Mentos" then
                    HealData.IsHealing = false
                end
            end)

            while HealData.IsHealing and HealData.SessionID == currentSession do
                local currentCharacter = Player.Character
                local backpack = Player.Backpack
                
                if currentCharacter and backpack then
                    local humanoid = currentCharacter:FindFirstChild("Humanoid")
                    local healItems = {}
                    
                    for _, item in ipairs(backpack:GetChildren()) do
                        if item.Name == "Pizza" or item.Name == "Mentos" then
                            table.insert(healItems, item)
                        end
                    end

                    if #healItems > 0 and humanoid and humanoid.Health > 0 then
                        local comboCount = 0
                        for i = 1, #healItems do
                            if not HealData.IsHealing or HealData.SessionID ~= currentSession then break end
                            
                            local targetTool = healItems[i]
                            if targetTool and targetTool.Parent == backpack then
                                humanoid:EquipTool(targetTool)
                                targetTool:Activate()
                                
                                task.wait((humanoid.Health < 30) and 0.01 or 0.1)
                                
                                comboCount = comboCount + 1
                                if comboCount >= 5 then
                                    humanoid:UnequipTools()
                                    task.wait(0.1)
                                    comboCount = 0
                                end
                            end
                        end
                    elseif #healItems == 0 then
                        HealData.IsHealing = false
                    end
                end
                task.wait(0.05)
            end
            
            if toolChangeConn then toolChangeConn:Disconnect() end
            HealBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            HealBtn.Text = "HEAL"
        end)
    end
end)
