-- ========== MISC VARIABLES ==========
local InfStamina = false
local InstantInteract = false
local CamNoclip = false
local originalDurations = {}

-- ========== MISC FUNCTIONS ==========
local function ApplyInstant(obj)
    if obj:IsA("ProximityPrompt") then
        if not originalDurations[obj] then
            originalDurations[obj] = obj.HoldDuration
        end
        obj.HoldDuration = InstantInteract and 0 or (originalDurations[obj] or 0)
    end
end

workspace.DescendantAdded:Connect(ApplyInstant)
for _, obj in pairs(workspace:GetDescendants()) do
    ApplyInstant(obj)
end

-- ========== SILENT AIM 100% CHÍNH XÁC ==========
local SilentAimEnabled = false
local SelectedBodyPart = "Head"
local BodyPartOptions = {"Head", "HumanoidRootPart"}
local MaxDistance = 1000000

-- Danh sách tên không bao giờ aim
local NeverAimNames = {"khangggggggggg646"}

local FOVCircle = Drawing.new("Circle")
FOVCircle.Radius = 150
FOVCircle.Thickness = 0.5
FOVCircle.Filled = false
FOVCircle.Color = Color3.fromRGB(255,0,0)
FOVCircle.Visible = false

local ShowFov = false

local tracerLine = Drawing.new("Line")
tracerLine.Color = Color3.fromRGB(255,0,0)
tracerLine.Thickness = 2
tracerLine.Visible = false

local currentTarget = nil
local targetPart = nil

local function GetTargetPart(character)
    if not character then return nil end
    if SelectedBodyPart == "Head" then
        return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    else
        return character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head")
    end
end

local function IsNeverAim(player)
    if not player then return false end
    for _, name in ipairs(NeverAimNames) do
        if player.Name == name then
            return true
        end
    end
    return false
end

local function GetClosestTarget()
    local closest = nil
    local shortest = math.huge
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if IsNeverAim(player) then continue end -- Bỏ qua nếu tên trong danh sách
        
        local character = player.Character
        if not character then continue end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        
        local part = GetTargetPart(character)
        if not part then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        
        if ShowFov then
            if dist < FOVCircle.Radius and dist < shortest then
                shortest = dist
                closest = player
                targetPart = part
            end
        else
            if dist < shortest then
                shortest = dist
                closest = player
                targetPart = part
            end
        end
    end
    
    return closest
end

-- HOOK RAYCAST
local oldNameCall
oldNameCall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if SilentAimEnabled and method == "Raycast" and self == Workspace and not checkcaller() then
        if currentTarget and currentTarget.Character and targetPart and targetPart.Parent and not IsNeverAim(currentTarget) then
            local origin = args[1]
            local direction = (targetPart.Position - origin).Unit * MaxDistance
            args[2] = direction
            return oldNameCall(self, unpack(args))
        end
    end
    
    return oldNameCall(self, ...)
end))

-- HOOK FIRESERVER
local function FindSendRemote()
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") and (v.Name:lower():find("send") or v.Name:lower():find("shoot") or v.Name:lower():find("fire") or v.Name:lower():find("bullet")) then
            return v
        end
    end
    return nil
end

local send = FindSendRemote()
local oldFire

if send then
    oldFire = hookfunction(send.FireServer, function(self, ...)
        local args = {...}

        if SilentAimEnabled and currentTarget and currentTarget.Character and targetPart and targetPart.Parent and not IsNeverAim(currentTarget) then
            local myHead = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local origin = myHead or myRoot
            
            if origin then
                for i, v in pairs(args) do
                    if typeof(v) == "table" then
                        for j, bullet in pairs(v) do
                            if typeof(bullet) == "table" then
                                if bullet.Instance then
                                    bullet.Instance = targetPart
                                end
                                if bullet.Position then
                                    bullet.Position = targetPart.Position
                                end
                                if bullet.Velocity then
                                    bullet.Velocity = Vector3.zero
                                end
                                if bullet.Direction then
                                    bullet.Direction = (targetPart.Position - origin.Position).Unit
                                end
                            end
                        end
                    end
                end
                
                for i, v in pairs(args) do
                    if typeof(v) == "CFrame" then
                        args[i] = CFrame.lookAt(origin.Position, targetPart.Position)
                    end
                end
                
                for i, v in pairs(args) do
                    if typeof(v) == "Vector3" and i > 1 then
                        args[i] = targetPart.Position
                    end
                end
            end
        end

        return oldFire(self, unpack(args))
    end)
end

RunService.RenderStepped:Connect(function()
    if SilentAimEnabled then
        currentTarget = GetClosestTarget()
    else
        currentTarget = nil
        targetPart = nil
    end
    
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    FOVCircle.Visible = ShowFov
    
    if SilentAimEnabled and currentTarget and currentTarget.Character and targetPart and targetPart.Parent and not IsNeverAim(currentTarget) then
        local screen, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if onScreen then
            tracerLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            tracerLine.To = Vector2.new(screen.X, screen.Y)
            tracerLine.Visible = true
        else
            tracerLine.Visible = false
        end
    else
        tracerLine.Visible = false
    end
    
    local char = LocalPlayer.Character
    if char then
        if InfStamina then
            char:SetAttribute("Stamina", 120)
        end
        
        if CamNoclip then
            LocalPlayer.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Invisicam
        else
            LocalPlayer.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Zoom
        end
    end
end)

-- ========== ESP ==========
local ESPs = {}
local ShowESP = false
local EspShowName = false
local EspShowHealth = false
local EspChams = false
local PlayerNameLabels = {}
local PlayerHealthBars = {}

local function NewBox()
    local box = {Lines={}}
    for i=1,12 do
        local line = Drawing.new("Line")
        line.Color = Color3.fromRGB(255,255,255)
        line.Thickness = 1.9
        line.Visible = false
        table.insert(box.Lines, line)
    end
    function box:Remove()
        for _, l in ipairs(self.Lines) do
            if l then pcall(function() l:Remove() end) end
        end
    end
    return box
end

local function SetupPlayerESP(player)
    if player == LocalPlayer then return end
    if ESPs[player] then return end
    
    local entry = {box = NewBox(), char = player.Character, chams = nil}
    
    local chams = Instance.new("Highlight")
    chams.Name = "Chams"
    chams.FillColor = Color3.fromRGB(255, 0, 0)
    chams.OutlineColor = Color3.fromRGB(255, 255, 255)
    chams.FillTransparency = 0.5
    chams.OutlineTransparency = 0
    chams.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    chams.Enabled = false
    
    entry.chams = chams
    ESPs[player] = entry
    
    player.CharacterAdded:Connect(function(char)
        entry.char = char
    end)
    
    player.CharacterRemoving:Connect(function()
        entry.char = nil
        for _, l in ipairs(entry.box.Lines) do l.Visible = false end
        if entry.chams then
            entry.chams.Enabled = false
            entry.chams.Parent = nil
        end
        if PlayerNameLabels[player] then PlayerNameLabels[player].Visible = false end
        if PlayerHealthBars[player] then PlayerHealthBars[player].Visible = false end
    end)
end

local function CleanupPlayerESP(player)
    if ESPs[player] then
        ESPs[player].box:Remove()
        if ESPs[player].chams then
            ESPs[player].chams:Destroy()
        end
        ESPs[player] = nil
    end
    if PlayerNameLabels[player] then PlayerNameLabels[player]:Remove(); PlayerNameLabels[player]=nil end
    if PlayerHealthBars[player] then PlayerHealthBars[player]:Remove(); PlayerHealthBars[player]=nil end
end

for _, p in ipairs(Players:GetPlayers()) do SetupPlayerESP(p) end
Players.PlayerAdded:Connect(SetupPlayerESP)
Players.PlayerRemoving:Connect(CleanupPlayerESP)

