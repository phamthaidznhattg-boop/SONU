-- ========== RENDER STEPPED ESP ==========
RunService.RenderStepped:Connect(function()
    for player, entry in pairs(ESPs) do
        if entry.chams and EspChams then
            if player.Character and player.Character.PrimaryPart then
                entry.chams.Parent = player.Character
                entry.chams.Enabled = true
            else
                entry.chams.Enabled = false
                entry.chams.Parent = nil
            end
        end
    end
    
    for player, entry in pairs(ESPs) do
        local char = entry.char
        local box = entry.box
        if not char then
            for _, l in ipairs(box.Lines) do l.Visible = false end
            if PlayerNameLabels[player] then PlayerNameLabels[player].Visible = false end
            if PlayerHealthBars[player] then PlayerHealthBars[player].Visible = false end
            continue
        end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not humanoid or humanoid.Health <= 0 then
            for _, l in ipairs(box.Lines) do l.Visible = false end
            if PlayerNameLabels[player] then PlayerNameLabels[player].Visible = false end
            if PlayerHealthBars[player] then PlayerHealthBars[player].Visible = false end
            continue
        end

        local height = humanoid.HipHeight * 2 + hrp.Size.Y
        local width  = hrp.Size.X * 2 * 1.19
        local depth  = hrp.Size.Z * 2 * 1.15

        local corners = {
            Vector3.new(-width/2, -height/2, -depth/2),
            Vector3.new( width/2, -height/2, -depth/2),
            Vector3.new( width/2, -height/2,  depth/2),
            Vector3.new(-width/2, -height/2,  depth/2),
            Vector3.new(-width/2,  height/2, -depth/2),
            Vector3.new( width/2,  height/2, -depth/2),
            Vector3.new( width/2,  height/2,  depth/2),
            Vector3.new(-width/2,  height/2,  depth/2),
        }

        local pts = {}
        local anyOnScreen = false
        for i, off in ipairs(corners) do
            local wp = hrp.CFrame:PointToWorldSpace(off)
            local s, onScreen = Camera:WorldToViewportPoint(wp)
            pts[i] = Vector2.new(s.X, s.Y)
            if onScreen then anyOnScreen = true end
        end

        local isTarget = (player == currentTarget)
        local color = isTarget and Color3.fromRGB(255,0,0) or Color3.fromRGB(255,255,255)

        if ShowESP and anyOnScreen then
            local lines = box.Lines
            for _, line in ipairs(lines) do line.Color = color end
            local edgeIndex = {
                {1,2},{2,3},{3,4},{4,1},
                {5,6},{6,7},{7,8},{8,5},
                {1,5},{2,6},{3,7},{4,8}
            }
            for i, pair in ipairs(edgeIndex) do
                local l = lines[i]
                l.From = pts[pair[1]]
                l.To   = pts[pair[2]]
                l.Visible = true
            end
        else
            for _, l in ipairs(box.Lines) do l.Visible = false end
        end

        local topMiddle = Vector2.new(
            (pts[5].X + pts[6].X + pts[7].X + pts[8].X)/4,
            (pts[5].Y + pts[6].Y + pts[7].Y + pts[8].Y)/4
        )

        if EspShowHealth and anyOnScreen then
            local txt = PlayerHealthBars[player] or Drawing.new("Text")
            if not PlayerHealthBars[player] then
                txt.Size = 12
                txt.Center = true
                txt.Outline = true
                txt.OutlineColor = Color3.fromRGB(0,0,0)
                txt.Font = 3
                PlayerHealthBars[player] = txt
            end
            local ratio = humanoid.Health / humanoid.MaxHealth
            txt.Text = string.format("[%d/%d]", math.floor(humanoid.Health), math.floor(humanoid.MaxHealth))
            txt.Color = Color3.fromRGB(255 * (1 - ratio), 255 * ratio, 0)
            txt.Position = topMiddle + Vector2.new(0, -15)
            txt.Visible = true
        elseif PlayerHealthBars[player] then
            PlayerHealthBars[player].Visible = false
        end

        if EspShowName and anyOnScreen then
            local label = PlayerNameLabels[player] or Drawing.new("Text")
            if not PlayerNameLabels[player] then
                label.Center = true
                label.Outline = true
                label.OutlineColor = Color3.fromRGB(0,0,0)
                label.Size = 14
                label.Font = 3
                PlayerNameLabels[player] = label
            end
            label.Text = player.Name
            label.Position = topMiddle + Vector2.new(0, -28)
            label.Color = color
            label.Visible = true
        elseif PlayerNameLabels[player] then
            PlayerNameLabels[player].Visible = false
        end
    end
end)

