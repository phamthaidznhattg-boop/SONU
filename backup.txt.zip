local mt = getrawmetatable(game)
local rawNamecall = mt.__namecall
local rawIndex = mt.__index
local rawNewIndex = mt.__newindex
local env = getfenv(0)

task.spawn(function()
    while true do
        task.wait(0.5)
        local cmt = getrawmetatable(game)
        if cmt.__namecall ~= rawNamecall then kill() break end
        if cmt.__index ~= rawIndex then kill() break end
        if cmt.__newindex ~= rawNewIndex then kill() break end
        if getfenv(0) ~= env then kill() break end
    end
end)

if not game:IsLoaded() then
    repeat task.wait() until game:IsLoaded()
end

